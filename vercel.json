{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": null,
  "installCommand": null,
  "outputDirectory": null,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/stats",
      "destination": "/stats.html"
    },
    {
      "source": "/config",
      "destination": "/config.html"
    },
    {
      "source": "/mistats",
      "destination": "/mistats.html"
    },
    {
      "source": "/calendar",
      "destination": "/calendar.html"
    },
    {
      "source": "/manifest.json",
      "destination": "/manifest.json"
    }
  ],
  "functions": {
    "api/data.py": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/task.py": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/stats.py": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/config.py": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/push.py": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/calendar.py": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/review.py": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/reviews.py": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/voice_note.py": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/daily_summary.py": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/review_attachment.py": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/trigger.py": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/client_videos.py": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/clients_with_stats.py": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/bulk_approve_existing.py": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/admin_cleanup_raw_files.py": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/admin_sync_edited_with_drive.py": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/admin_drive_audit.py": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/admin_merge_clientes.py": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/admin_strict_sync_client.py": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/trigger",
      "schedule": "* * * * *"
    }
  ]
}